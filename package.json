{
  "name": "ruoyi",
  "version": "3.8.5",
  "description": "Edge Terminal",
  "author": "Edge Terminal",
  "license": "MIT",
  "scripts": {
    "dev": "NODE_OPTIONS=--openssl-legacy-provider vue-cli-service serve",
    "build:linux": "NODE_OPTIONS=--openssl-legacy-provider vue-cli-service build --mode linux",
    "build:windows": "NODE_OPTIONS=--openssl-legacy-provider vue-cli-service build --mode windows",
    "build:report": "NODE_OPTIONS=--openssl-legacy-provider vue-cli-service build --mode windows --report",
    "preview": "node build/index.js --preview",
    "lint": "eslint --ext .js,.vue src"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "src/**/*.{js,vue}": [
      "eslint --fix",
      "git add"
    ]
  },
  "keywords": [
    "vue",
    "admin",
    "dashboard",
    "element-ui",
    "boilerplate",
    "admin-template",
    "management-system"
  ],
  "repository": {
    "type": "git",
    "url": "https://gitee.com/y_project/RuoYi-Vue.git"
  },
  "dependencies": {
    "@jiaminghi/data-view": "^2.10.0",
    "@mapbox/mapbox-gl-language": "^1.0.1",
    "@riophae/vue-treeselect": "0.4.0",
    "ailabel": "^5.1.15",
    "axios": "0.24.0",
    "check-network-status": "^1.2.3",
    "clipboard": "2.0.8",
    "core-js": "3.25.3",
    "cos-js-sdk-v5": "^1.10.1",
    "dayjs": "^1.11.13",
    "echarts": "5.4.0",
    "element-ui": "2.15.12",
    "file-saver": "2.0.5",
    "fuse.js": "6.4.3",
    "highlight.js": "9.18.5",
    "internet-available": "^1.0.0",
    "js-beautify": "1.13.0",
    "js-cookie": "3.0.1",
    "js-md5": "^0.7.3",
    "jsencrypt": "3.0.0-rc.1",
    "jspdf": "^2.5.2",
    "lodash": "^4.17.21",
    "mapbox-gl": "^2.15.0",
    "marked": "^4.3.0",
    "nprogress": "0.2.0",
    "quill": "1.3.7",
    "resize-observer-polyfill": "^1.5.1",
    "screenfull": "5.0.2",
    "sortablejs": "1.10.2",
    "vue": "2.6.12",
    "vue-count-to": "1.0.13",
    "vue-cropper": "0.5.5",
    "vue-fullscreen": "^2.6.1",
    "vue-i18n": "^7.3.2",
    "vue-meta": "2.4.0",
    "vue-router": "3.4.9",
    "vue-sqlite": "^0.0.0",
    "vuedraggable": "2.24.3",
    "vuex": "3.6.0"
  },
  "devDependencies": {
    "@vue/cli-plugin-babel": "4.4.6",
    "@vue/cli-plugin-eslint": "4.4.6",
    "@vue/cli-service": "4.4.6",
    "babel-eslint": "10.1.0",
    "babel-plugin-dynamic-import-node": "2.3.3",
    "chalk": "4.1.0",
    "compression-webpack-plugin": "5.0.2",
    "connect": "3.6.6",
    "eslint": "7.15.0",
    "eslint-plugin-vue": "7.2.0",
    "lint-staged": "10.5.3",
    "runjs": "4.4.2",
    "sass": "1.32.13",
    "sass-loader": "10.1.1",
    "script-ext-html-webpack-plugin": "2.1.5",
    "svg-sprite-loader": "5.1.1",
    "vue-template-compiler": "2.6.12",
    "webpack-bundle-analyzer": "^5.0.1"
  },
  "engines": {
    "node": ">=16.0",
    "npm": ">=3.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions"
  ]
}